---
import LearnLayout from '../../../../layouts/LearnLayout.astro';
import KeyVerbsContent from '../../../../components/learn/KeyVerbsContent.astro';
import { locales, isLocale, type Locale } from '../../../../i18n/site';

export function getStaticPaths() {
  return locales
    .filter((l) => l !== 'en')
    .map((l) => ({ params: { lang: l } }));
}

const { lang } = Astro.params;
if (!isLocale(lang) || lang === 'en') throw new Error(`Unsupported locale: ${lang}`);
const locale = lang as Locale;
---
<LearnLayout
  title="Key English Verbs for Natural Speech | SpeakPath"
  description="The 30 most-used verbs in English with their core patterns. Master these and you can express almost anything in a real conversation."
  currentSlug="key-verbs"
  locale={locale}
>
  <KeyVerbsContent locale={locale} />
</LearnLayout>
