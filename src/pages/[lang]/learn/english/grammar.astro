---
import LearnLayout from '../../../../layouts/LearnLayout.astro';
import GrammarContent from '../../../../components/learn/GrammarContent.astro';
import { locales, isLocale, type Locale } from '../../../../i18n/site';

export function getStaticPaths() {
  return locales
    .filter((l) => l !== 'en')
    .map((l) => ({ params: { lang: l } }));
}

const { lang } = Astro.params;
if (!isLocale(lang) || lang === 'en') throw new Error(`Unsupported locale: ${lang}`);
const locale = lang as Locale;

const localizedMeta = {
  en: {
    title: 'English Grammar Fundamentals — Write Better to Speak Better | SpeakPath',
    description:
      'Master the core English grammar rules — auxiliary verbs, tenses, and sentence structures that form the foundation of natural, confident speech.',
  },
  es: {
    title: 'Gramática esencial del inglés — Escribe mejor para hablar mejor | SpeakPath',
    description:
      'Aprende las reglas centrales de la gramática inglesa con explicaciones en español: verbos auxiliares, preguntas, negaciones y estructuras para hablar con más confianza.',
  },
  fr: {
    title: 'Grammaire essentielle de l’anglais — Écrire mieux pour mieux parler | SpeakPath',
    description:
      'Apprenez les règles essentielles de la grammaire anglaise avec des explications en français : auxiliaires, questions, négations et structures pour parler avec plus de confiance.',
  },
  de: {
    title: 'Englische Grammatik verstehen — Besser schreiben, besser sprechen | SpeakPath',
    description:
      'Lerne die zentralen Regeln der englischen Grammatik mit Erklärungen auf Deutsch: Hilfsverben, Fragen, Verneinungen und Satzstrukturen für sichereres Sprechen.',
  },
  pt: {
    title: 'Gramática essencial do inglês — Escreva melhor para falar melhor | SpeakPath',
    description:
      'Aprenda as regras centrais da gramática inglesa com explicações em português: verbos auxiliares, perguntas, negativas e estruturas para falar com mais confiança.',
  },
};
const meta = localizedMeta[locale];
---
<LearnLayout
  title={meta.title}
  description={meta.description}
  currentSlug="grammar"
  locale={locale}
>
  <GrammarContent locale={locale} />
</LearnLayout>
