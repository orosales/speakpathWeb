---
import type { LocalizedPageCopy } from '../i18n/site';

interface Props {
  copy: LocalizedPageCopy['levels'];
}

const { copy } = Astro.props;
---

<section class="bg-surface-container-lowest py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="mb-12">
      <p class="text-tertiary text-xs font-headline tracking-[0.2em] uppercase font-semibold mb-4">
        {copy.eyebrow}
      </p>
      <h2 class="font-headline text-3xl md:text-4xl font-bold tracking-display">
        {copy.title}
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {copy.items.map((level) => (
        <div class="glass p-8 rounded-2xl ghost-border group hover:shadow-[0_0_40px_rgba(88,245,209,0.06)] transition-all duration-300">
          <h3 class="text-primary font-bold text-xl mb-4 font-headline">{level.name}</h3>
          <p class="text-on-surface-variant mb-8 leading-relaxed text-sm">{level.body}</p>

          <!-- Progress bar -->
          <div class="h-1 bg-surface-variant rounded-full overflow-hidden">
            <div
              class={`h-full ${level.fill} rounded-full`}
              style="background: linear-gradient(90deg, #58f5d1, #1cd0ad);"
            ></div>
          </div>
        </div>
      ))}
    </div>

    <p class="mt-8 text-on-surface-variant text-sm flex items-center gap-2">
      <span class="material-symbols-outlined text-sm text-primary">auto_awesome</span>
      {copy.note}
    </p>
  </div>
</section>
