---
const APP_URL = 'https://app.speakpath.dev';

const bars = [
  { height: '40%', color: 'primary', delay: '0s', duration: '1.2s' },
  { height: '72%', color: 'primary', delay: '0.14s', duration: '1.45s' },
  { height: '56%', color: 'primary', delay: '0.28s', duration: '1.15s' },
  { height: '88%', color: 'tertiary', delay: '0.38s', duration: '1.6s' },
  { height: '35%', color: 'primary', delay: '0.52s', duration: '1.25s' },
  { height: '68%', color: 'primary', delay: '0.18s', duration: '1.4s' },
  { height: '84%', color: 'tertiary', delay: '0.64s', duration: '1.5s' },
  { height: '50%', color: 'primary', delay: '0.32s', duration: '1.3s' },
  { height: '76%', color: 'primary', delay: '0.48s', duration: '1.55s' },
  { height: '44%', color: 'primary', delay: '0.22s', duration: '1.2s' },
];

const barGradients = {
  primary: 'linear-gradient(to top, rgba(88, 245, 209, 1), rgba(88, 245, 209, 0))',
  tertiary: 'linear-gradient(to top, rgba(200, 125, 255, 1), rgba(200, 125, 255, 0))',
};
---

<section class="relative isolate px-6 pb-24 pt-14 md:px-12 md:pb-28 md:pt-20 max-w-7xl mx-auto">
  <div
    class="pointer-events-none absolute left-[-14%] top-[-14%] h-[30rem] w-[30rem] rounded-full opacity-40 blur-[110px]"
    style="background: radial-gradient(circle, rgba(88,245,209,0.16) 0%, rgba(88,245,209,0) 72%);"
  ></div>
  <div
    class="pointer-events-none absolute bottom-[-18%] right-[-10%] h-[34rem] w-[34rem] rounded-full opacity-40 blur-[140px]"
    style="background: radial-gradient(circle, rgba(200,125,255,0.12) 0%, rgba(200,125,255,0) 72%);"
  ></div>

  <div class="relative grid items-center gap-14 lg:grid-cols-[minmax(0,1.02fr)_minmax(24rem,33rem)] lg:gap-10">
    <div class="max-w-2xl">
      <p class="mb-6 inline-flex rounded-full bg-secondary-container px-4 py-2 text-[0.68rem] font-bold uppercase tracking-[0.24em] text-primary font-headline">
        AI-Powered Fluency Engine
      </p>

      <h1 class="font-headline text-5xl font-extrabold leading-[0.98] tracking-display text-on-surface md:text-7xl lg:text-[5.2rem]">
        Speak.<br />
        <span
          style="background: linear-gradient(135deg, #58f5d1 0%, #1cd0ad 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
        >
          Learn.
        </span>
        <br />
        Improve.
      </h1>

      <p class="mt-6 max-w-xl text-base leading-8 text-on-surface-variant md:text-xl md:leading-9">
        Master any language with high-precision audio analysis. SpeakPath uses neural
        frequency mapping to refine your accent and rhythm in real-time.
      </p>

      <div class="mt-10 flex flex-col items-start gap-5 sm:flex-row sm:items-center">
        <a href={APP_URL} class="btn-primary group">
          Start Practicing Free
          <span class="material-symbols-outlined arrow text-xl">arrow_forward</span>
        </a>
        <p class="text-sm text-on-surface-variant">
          No credit card. No setup. Just open it and talk.
        </p>
      </div>
    </div>

    <div class="relative flex justify-center lg:justify-end">
      <div
        class="glass ghost-border relative w-full max-w-[33rem] overflow-hidden rounded-[2rem] px-6 py-8 shadow-[0_30px_80px_rgba(0,0,0,0.35)] sm:px-8 sm:py-10 md:rounded-[2.5rem] md:px-10 md:py-12"
      >
        <div
          class="pointer-events-none absolute inset-x-12 top-6 h-24 rounded-full blur-3xl"
          style="background: radial-gradient(circle, rgba(200,125,255,0.18) 0%, rgba(200,125,255,0) 75%);"
        ></div>

        <div class="relative flex min-h-[23rem] flex-col justify-between gap-12 md:min-h-[26rem]">
          <div
            class="mx-auto flex h-44 w-full max-w-[18rem] items-end justify-center gap-2 sm:h-48"
            aria-hidden="true"
          >
            {bars.map((bar) => (
              <div
                class="waveform-bar w-3 rounded-full"
                style={`height: ${bar.height}; background: ${barGradients[bar.color]}; animation-delay: ${bar.delay}; animation-duration: ${bar.duration};`}
              ></div>
            ))}
          </div>

          <div class="flex items-center gap-5 sm:gap-6">
            <div class="relative flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-surface-bright shadow-[0_0_28px_rgba(88,245,209,0.16)] sm:h-20 sm:w-20">
              <div class="absolute inset-0 rounded-full border border-primary/20 animate-pulse-ring"></div>
              <div class="absolute inset-[0.4rem] rounded-full bg-primary/6 blur-sm"></div>
              <span
                class="material-symbols-outlined relative z-10 text-3xl text-primary sm:text-4xl"
                style="font-variation-settings: 'FILL' 1;"
              >
                mic
              </span>
            </div>

            <div class="min-w-0">
              <p class="font-headline text-[0.68rem] font-bold uppercase tracking-[0.24em] text-primary">
                AI Companion
              </p>
              <p class="mt-1 font-headline text-xl font-bold text-on-surface sm:text-[1.65rem]">
                Responding in Real-time...
              </p>

              <div class="mt-3 h-1.5 w-full max-w-[15rem] overflow-hidden rounded-full bg-surface-container">
                <div class="h-full w-3/4 rounded-full bg-primary"></div>
              </div>

              <p class="mt-3 text-[0.65rem] uppercase tracking-[0.18em] text-on-surface-variant/70">
                French • English • German • Spanish
              </p>
            </div>
          </div>
        </div>

        <div
          class="pointer-events-none absolute inset-x-0 bottom-[-3rem] mx-auto h-24 w-[70%] rounded-full blur-3xl"
          style="background: radial-gradient(circle, rgba(88,245,209,0.14) 0%, rgba(88,245,209,0) 75%);"
        ></div>
      </div>
    </div>
  </div>
</section>
