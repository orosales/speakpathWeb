---
interface Step {
  slug: string;
  label: string;
  path: string;
}

interface Props {
  currentSlug: string;
  basePath?: string;
  locale?: string;
}

const { currentSlug, basePath = '/learn/english', locale = 'en' } = Astro.props;

const labels = {
  en: { path: 'The Path', steps: ['Grammar', 'Key Verbs', 'Connectors', 'Phrasal Verbs', 'Nouns', 'Essay Template'] },
  es: { path: 'La ruta', steps: ['Gramática', 'Verbos clave', 'Conectores', 'Phrasal verbs', 'Sustantivos', 'Plantilla de ensayo'] },
  fr: { path: 'Le parcours', steps: ['Grammaire', 'Verbes clés', 'Connecteurs', 'Verbes à particule', 'Noms', 'Plan de rédaction'] },
  de: { path: 'Der Pfad', steps: ['Grammatik', 'Schlüsselverben', 'Konnektoren', 'Phrasal Verbs', 'Nomen', 'Aufsatzvorlage'] },
  pt: { path: 'O caminho', steps: ['Gramática', 'Verbos-chave', 'Conectores', 'Phrasal verbs', 'Substantivos', 'Modelo de redação'] },
};

const copy = labels[locale as keyof typeof labels] ?? labels.en;
const slugs = ['grammar', 'key-verbs', 'connectors', 'phrasal-verbs', 'nouns', 'essay-template'];
const steps: Step[] = slugs.map((slug, index) => ({
  slug,
  label: copy.steps[index],
  path: `${basePath}/${slug}`,
}));

const currentIndex = steps.findIndex(s => s.slug === currentSlug);
---

<!-- Desktop sidebar -->
<nav class="hidden lg:flex flex-col gap-1 w-52 shrink-0" aria-label="Learning steps">
  <p class="text-on-surface-variant text-xs font-headline tracking-[0.18em] uppercase font-semibold mb-3 px-3">
    {copy.path}
  </p>
  {steps.map((step, i) => {
    const isActive = step.slug === currentSlug;
    return (
      <a
        href={step.path}
        aria-current={isActive ? 'page' : undefined}
        class:list={[
          'flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200',
          isActive
            ? 'bg-surface-container-high text-primary font-semibold'
            : 'text-on-surface-variant hover:text-on-surface hover:bg-surface-container',
        ]}
      >
        <span
          class:list={[
            'w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0 font-headline',
            isActive
              ? 'bg-primary text-on-primary'
              : i < currentIndex
              ? 'bg-surface-container-high text-primary border border-primary/40'
              : 'bg-surface-container text-on-surface-variant',
          ]}
        >
          {i + 1}
        </span>
        {step.label}
      </a>
    );
  })}
</nav>

<!-- Mobile step pills -->
<nav class="lg:hidden overflow-x-auto pb-2 -mx-4 px-4" aria-label="Learning steps">
  <div class="flex gap-2 w-max">
    {steps.map((step, i) => {
      const isActive = step.slug === currentSlug;
      return (
        <a
          href={step.path}
          aria-current={isActive ? 'page' : undefined}
          class:list={[
            'flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold whitespace-nowrap transition-all duration-200 border',
            isActive
              ? 'bg-primary text-on-primary border-primary'
              : 'bg-surface-container text-on-surface-variant border-outline-variant/20 hover:text-on-surface hover:border-outline-variant/50',
          ]}
        >
          <span class="font-bold">{i + 1}</span>
          {step.label}
        </a>
      );
    })}
  </div>
</nav>
