---
import type { LocalizedPageCopy } from '../i18n/site';

interface Props {
  copy: LocalizedPageCopy['languages'];
}

const { copy } = Astro.props;
---

<section class="bg-surface-container-low rounded-[48px] px-6 py-24 md:px-12 mx-4 mb-8">
  <div class="max-w-7xl mx-auto">
    <h2 class="font-headline text-3xl md:text-4xl font-bold tracking-display mb-4">
      {copy.title}
    </h2>
    <p class="text-on-surface-variant mb-12 max-w-sm">
      {copy.intro}
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {copy.cards.map((lang) => (
        <div
          class="card-hover ghost-border p-6 rounded-2xl cursor-pointer"
          role="button"
          tabindex="0"
          aria-label={`${lang.name} — ${lang.tagline}`}
        >
          <div class="text-4xl mb-4" aria-hidden="true">{lang.flag}</div>
          <h3 class="font-bold text-xl mb-1 font-headline">{lang.name}</h3>
          <p class="text-tertiary text-xs font-headline tracking-widest uppercase font-semibold">
            {lang.label}
          </p>
          <p class="text-on-surface-variant text-xs mt-2 leading-relaxed hidden md:block">
            {lang.tagline}
          </p>
        </div>
      ))}
    </div>

    <p class="mt-8 text-on-surface-variant text-sm flex items-center gap-2">
      <span class="material-symbols-outlined text-sm">schedule</span>
      {copy.moreSoon}
    </p>
  </div>
</section>
