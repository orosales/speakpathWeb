---
const APP_URL = 'https://app.speakpath.dev';
---

<section class="relative px-6 py-32 text-center max-w-4xl mx-auto overflow-hidden">
  <!-- Ambient glow -->
  <div
    class="pointer-events-none absolute inset-0 flex items-center justify-center"
    aria-hidden="true"
  >
    <div
      class="w-[600px] h-[300px] rounded-full opacity-10"
      style="background: radial-gradient(ellipse, #58f5d1 0%, transparent 70%);"
    ></div>
  </div>

  <div class="relative">
    <p class="text-tertiary text-xs font-headline tracking-[0.2em] uppercase font-semibold mb-6">
      Start today
    </p>

    <h2
      class="font-headline text-4xl md:text-6xl font-extrabold tracking-display mb-6 leading-tight"
    >
      Ready to start<br />speaking?
    </h2>

    <p class="text-on-surface-variant text-xl mb-12 font-body">
      No credit card. No setup. Just open it and talk.
    </p>

    <a
      href={APP_URL}
      class="inline-flex items-center gap-3 px-10 py-5 rounded-full font-bold text-xl font-headline group transition-all duration-300 hover:scale-105"
      style="background: linear-gradient(135deg, #58f5d1, #1cd0ad); color: #003f33; box-shadow: 0 0 40px rgba(88,245,209,0.2);"
    >
      Try SpeakPath Free
      <span
        class="material-symbols-outlined"
        style="transition: transform 0.2s ease;"
      >
        arrow_forward
      </span>
    </a>
  </div>
</section>

<style>
  a:hover .material-symbols-outlined {
    transform: translateX(4px);
  }
</style>
