---
import type { LocalizedPageCopy } from '../i18n/site';

interface Props {
  copy: LocalizedPageCopy['features'];
}

const { copy } = Astro.props;
---

<section class="px-6 py-24 md:px-12 max-w-7xl mx-auto">
  <div class="mb-16 text-center">
    <p class="text-tertiary text-xs font-headline tracking-[0.2em] uppercase font-semibold mb-4">
      {copy.eyebrow}
    </p>
    <h2 class="font-headline text-3xl md:text-4xl font-bold tracking-display">
      {copy.title}
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-y-10 gap-x-10">
    {copy.items.map((f) => (
      <div class="flex gap-4 group">
        <!-- Icon -->
        <div
          class="shrink-0 w-10 h-10 rounded-xl flex items-center justify-center bg-surface-container group-hover:bg-surface-container-high transition-colors duration-300"
          style="box-shadow: 0 0 0 1px rgba(59,72,97,0.15);"
        >
          <span class="material-symbols-outlined text-primary text-[1.1rem]">{f.icon}</span>
        </div>
        <div>
          <h4 class="font-bold mb-1.5 font-headline">{f.title}</h4>
          <p class="text-on-surface-variant text-sm leading-relaxed">{f.body}</p>
        </div>
      </div>
    ))}
  </div>
</section>
