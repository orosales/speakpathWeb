      { title: 'Konnektoren', description: 'Satzanfänge und Verbindungen, die deine Gedanken natürlich fließen lassen.' },
      { title: 'Phrasal Verbs', description: 'Kombinationen, die Muttersprachler ständig verwenden und Lernende oft vermeiden.' },
      { title: 'Kernnomen', description: 'Häufiger Wortschatz, der in echten Gesprächen immer wieder vorkommt.' },
      { title: 'Aufsatzvorlage', description: 'Eine Struktur, die alles verbindet: schriftliche Klarheit wird zu mündlicher Flüssigkeit.' },
    ],
