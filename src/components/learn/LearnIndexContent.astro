    practice: 'Praticar fala',
    steps: [
      { title: 'Gramática', description: 'Tempos verbais, estrutura da frase e as regras que sustentam tudo.' },
      { title: 'Verbos-chave', description: 'Os verbos mais usados em inglês: domine esses padrões e você conseguirá dizer muito mais.' },
      { title: 'Conectores', description: 'Aberturas e ligações que fazem suas ideias fluírem com naturalidade.' },
      { title: 'Phrasal verbs', description: 'Combinações que nativos usam o tempo todo e que estudantes costumam evitar.' },
      { title: 'Substantivos essenciais', description: 'Vocabulário frequente que aparece em conversas reais.' },
      { title: 'Modelo de redação', description: 'Uma estrutura para juntar tudo: clareza na escrita que vira fluência na fala.' },
    ],
  },
};

const copy = localized[locale as keyof typeof localized] ?? localized.en;

const slugs = ['grammar', 'key-verbs', 'connectors', 'phrasal-verbs', 'nouns', 'essay-template'];
const icons = ['menu_book', 'bolt', 'link', 'swap_horiz', 'category', 'description'];
const steps = copy.steps.map((step, index) => ({
  number: index + 1,
  slug: slugs[index],
  path: `${basePath}/${slugs[index]}`,
  title: step.title,
  description: step.description,
  icon: icons[index],
}));
---

<!-- Hero -->
<div class="mb-14">
  <p class="text-primary text-xs font-headline tracking-[0.2em] uppercase font-semibold mb-4">
    {copy.eyebrow}
  </p>
  <h1 class="font-headline text-3xl md:text-4xl lg:text-5xl font-bold tracking-display text-on-surface mb-6 leading-tight">
    {copy.titleTop}<br />
    <span class="text-primary">{copy.titleAccent}</span>
  </h1>
  <p class="text-on-surface-variant text-lg leading-relaxed max-w-2xl">
    {copy.intro}
  </p>
</div>

<!-- Personal story -->
<div class="mb-14 p-8 rounded-2xl bg-surface-container border border-outline-variant/15 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-48 h-48 rounded-full bg-primary/5 -translate-y-1/2 translate-x-1/2 blur-2xl pointer-events-none" />
  <p class="text-on-surface-variant text-xs font-headline tracking-[0.16em] uppercase font-semibold mb-5">
    {copy.method}
  </p>
  <div class="space-y-4 text-on-surface-variant leading-relaxed relative">
    {copy.paragraphs.map((paragraph) => (
      <p>{paragraph}</p>
    ))}
  </div>
</div>

<!-- 6-step overview -->
<div>
  <h2 class="font-headline text-xl font-bold mb-6 text-on-surface">
    {copy.pathTitle}
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {steps.map((step) => (
      <a
        href={step.path}
        class="group flex gap-4 p-5 rounded-2xl bg-surface-container border border-outline-variant/15 hover:border-primary/30 hover:bg-surface-container-high transition-all duration-200 no-underline"
      >
        <div class="shrink-0 flex flex-col items-center gap-2">
          <span class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm font-headline">
            {step.number}
          </span>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="material-symbols-outlined text-primary" style="font-size:18px">{step.icon}</span>
            <h3 class="font-headline font-semibold text-on-surface group-hover:text-primary transition-colors duration-200">
              {step.title}
            </h3>
          </div>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            {step.description}
          </p>
        </div>
        <span class="material-symbols-outlined text-on-surface-variant/40 group-hover:text-primary/60 self-center transition-colors shrink-0" style="font-size:20px">
          arrow_forward
        </span>
      </a>
    ))}
  </div>
</div>

<!-- CTA to start -->
<div class="mt-12 text-center p-8 rounded-2xl bg-surface-container-low border border-outline-variant/10">
  <h3 class="font-headline font-bold text-lg text-on-surface mb-2">{copy.ctaTitle}</h3>
  <p class="text-on-surface-variant text-sm mb-6">{copy.ctaBody}</p>
  <div class="flex flex-col sm:flex-row gap-3 justify-center">
    <a href={`${basePath}/grammar`} class="btn-primary inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold font-headline">
      {copy.begin}
      <span class="material-symbols-outlined" style="font-size:18px">arrow_forward</span>
    </a>
    <a
      href="https://app.speakpath.dev"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-on-surface-variant hover:text-on-surface hover:border-outline-variant/40 font-semibold font-headline text-sm transition-all duration-200"
    >
      {copy.practice}
      <span class="material-symbols-outlined" style="font-size:18px">open_in_new</span>
    </a>
  </div>
</div>
