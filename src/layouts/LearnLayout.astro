---
import '../styles/global.css';
import LearnNav from '../components/LearnNav.astro';
import { localeOgLocales, type Locale } from '../i18n/site';

interface Props {
  title: string;
  description: string;
  currentSlug: string;
  locale?: Locale;
}

const { title, description, currentSlug, locale = 'en' } = Astro.props;

const basePath = locale === 'en' ? '/learn/english' : `/${locale}/learn/english`;
const learnPath = locale === 'en' ? '/learn/' : `/${locale}/learn/`;
const homePath = locale === 'en' ? '/' : `/${locale}/`;

const labels = {
  en: {
    home: 'Home',
    learn: 'Learn',
    english: 'English',
    practice: 'Practice Speaking',
    ready: 'Ready to use what you learned?',
    previous: 'Previous',
    next: 'Next',
    done: "You're done!",
    mobilePractice: 'Put this into practice — speak with an AI that corrects you in real time.',
    footer: 'Precision Audio Engineering for Fluency.',
    privacy: 'Privacy',
  },
  es: {
    home: 'Inicio',
    learn: 'Aprender',
    english: 'Inglés',
    practice: 'Practicar hablando',
    ready: '¿Listo para usar lo que aprendiste?',
    previous: 'Anterior',
    next: 'Siguiente',
    done: 'Terminaste',
    mobilePractice: 'Pon esto en práctica: habla con una IA que te corrige en tiempo real.',
    footer: 'Ingeniería de audio de precisión para la fluidez.',
    privacy: 'Privacidad',
  },
  fr: {
    home: 'Accueil',
    learn: 'Apprendre',
    english: 'Anglais',
    practice: 'Pratiquer à l oral',
    ready: 'Prêt à utiliser ce que vous avez appris ?',
    previous: 'Précédent',
    next: 'Suivant',
    done: 'Vous avez terminé',
    mobilePractice: 'Mettez cela en pratique : parlez avec une IA qui vous corrige en temps réel.',
    footer: 'Ingénierie audio de précision au service de la fluidité.',
    privacy: 'Confidentialité',
  },
  de: {
    home: 'Start',
    learn: 'Lernen',
    english: 'Englisch',
    practice: 'Sprechen üben',
    ready: 'Bereit, das Gelernte anzuwenden?',
    previous: 'Zurück',
    next: 'Weiter',
    done: 'Fertig',
    mobilePractice: 'Setze es in die Praxis um: Sprich mit einer KI, die dich in Echtzeit korrigiert.',
    footer: 'Präzises Audio-Engineering für echte Sprachflüssigkeit.',
    privacy: 'Datenschutz',
  },
  pt: {
    home: 'Início',
    learn: 'Aprender',
    english: 'Inglês',
    practice: 'Praticar fala',
    ready: 'Pronto para usar o que aprendeu?',
    previous: 'Anterior',
    next: 'Próximo',
    done: 'Você terminou',
    mobilePractice: 'Coloque isso em prática: fale com uma IA que corrige você em tempo real.',
    footer: 'Engenharia de áudio de precisão para fluência.',
    privacy: 'Privacidade',
  },
};

const copy = labels[locale as keyof typeof labels] ?? labels.en;
const ogLocale = localeOgLocales[locale] ?? localeOgLocales.en;

const STEPS = [
  { slug: 'grammar',        label: locale === 'es' ? 'Gramática' : locale === 'fr' ? 'Grammaire' : locale === 'de' ? 'Grammatik' : locale === 'pt' ? 'Gramática' : 'Grammar', path: `${basePath}/grammar` },
  { slug: 'key-verbs',      label: locale === 'es' ? 'Verbos clave' : locale === 'fr' ? 'Verbes clés' : locale === 'de' ? 'Schlüsselverben' : locale === 'pt' ? 'Verbos-chave' : 'Key Verbs', path: `${basePath}/key-verbs` },
  { slug: 'connectors',     label: locale === 'es' ? 'Conectores' : locale === 'fr' ? 'Connecteurs' : locale === 'de' ? 'Konnektoren' : locale === 'pt' ? 'Conectores' : 'Connectors', path: `${basePath}/connectors` },
  { slug: 'phrasal-verbs',  label: locale === 'fr' ? 'Verbes à particule' : locale === 'de' ? 'Phrasal Verbs' : 'Phrasal verbs', path: `${basePath}/phrasal-verbs` },
  { slug: 'nouns',          label: locale === 'es' ? 'Sustantivos' : locale === 'fr' ? 'Noms' : locale === 'de' ? 'Nomen' : locale === 'pt' ? 'Substantivos' : 'Nouns', path: `${basePath}/nouns` },
  { slug: 'essay-template', label: locale === 'es' ? 'Plantilla de ensayo' : locale === 'fr' ? 'Plan de rédaction' : locale === 'de' ? 'Aufsatzvorlage' : locale === 'pt' ? 'Modelo de redação' : 'Essay Template', path: `${basePath}/essay-template` },
];

const currentIndex = STEPS.findIndex(s => s.slug === currentSlug);
const prevStep = currentIndex > 0 ? STEPS[currentIndex - 1] : null;
const nextStep = currentIndex < STEPS.length - 1 ? STEPS[currentIndex + 1] : null;
const isIndex = currentSlug === '';

const siteUrl = 'https://speakpath.dev';
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#010e24" />
    <link rel="canonical" href={`${siteUrl}${Astro.url.pathname}`} />

    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type"        content="article" />
    <meta property="og:url"         content={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:site_name"   content="SpeakPath" />
    <meta property="og:image"       content={`${siteUrl}/og-image.png`} />
    <meta property="og:locale"      content={ogLocale} />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${siteUrl}/og-image.png`} />

    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
    />
  </head>

  <body class="min-h-screen bg-surface text-on-surface font-body">
    <!-- Top nav -->
    <nav class="fixed top-0 w-full z-50 bg-surface/95 backdrop-blur-sm border-b border-outline-variant/10">
      <div class="flex justify-between items-center gap-4 px-6 md:px-8 py-5 max-w-7xl mx-auto">
        <a href={homePath} class="flex items-center gap-2 no-underline">
          <span class="material-symbols-outlined text-primary text-2xl" style="font-variation-settings: 'FILL' 1;">
            graphic_eq
          </span>
          <span class="text-xl font-bold tracking-tighter text-primary font-headline">SpeakPath</span>
        </a>
        <div class="flex items-center gap-5">
          <a href={learnPath} class="text-on-surface-variant text-sm hover:text-primary transition-colors duration-200 font-medium">
            {copy.learn}
          </a>
          <a
            href="https://app.speakpath.dev"
            class="btn-primary inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-semibold font-headline"
          >
            {copy.practice}
            <span class="material-symbols-outlined text-base leading-none" style="font-size:16px">arrow_forward</span>
          </a>
        </div>
      </div>
    </nav>

    <div class="pt-20 min-h-screen">
      <!-- Breadcrumb -->
      <div class="border-b border-outline-variant/10 bg-surface-container-low/50">
        <div class="max-w-7xl mx-auto px-6 md:px-8 py-3 flex items-center gap-2 text-xs text-on-surface-variant">
          <a href={homePath} class="hover:text-primary transition-colors">{copy.home}</a>
          <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
          <a href={learnPath} class="hover:text-primary transition-colors">{copy.learn}</a>
          <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
          <a href={basePath} class="hover:text-primary transition-colors">{copy.english}</a>
          {!isIndex && (
            <>
              <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
              <span class="text-on-surface">{STEPS[currentIndex]?.label}</span>
            </>
          )}
        </div>
      </div>

      <!-- Mobile step pills -->
      {!isIndex && (
        <div class="lg:hidden border-b border-outline-variant/10 bg-surface-container-low/30 px-4 py-3">
          <LearnNav currentSlug={currentSlug} basePath={basePath} locale={locale} />
        </div>
      )}

      <!-- Main layout -->
      <div class="max-w-7xl mx-auto px-6 md:px-8 py-10 flex gap-12">
        <!-- Sticky sidebar (desktop) -->
        {!isIndex && (
          <aside class="hidden lg:block sticky top-28 self-start">
            <LearnNav currentSlug={currentSlug} basePath={basePath} locale={locale} />

            <!-- Practice CTA in sidebar -->
            <div class="mt-8 p-4 rounded-2xl bg-surface-container border border-outline-variant/15">
              <p class="text-xs text-on-surface-variant mb-3 leading-relaxed">
                {copy.ready}
              </p>
              <a
                href="https://app.speakpath.dev"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-xl text-sm font-semibold font-headline w-full"
              >
                {copy.practice}
                <span class="material-symbols-outlined text-base leading-none" style="font-size:15px">open_in_new</span>
              </a>
            </div>
          </aside>
        )}

        <!-- Page content -->
        <article class="flex-1 min-w-0">
          <slot />

          <!-- Prev / Next navigation -->
          {!isIndex && (
            <nav class="mt-16 pt-8 border-t border-outline-variant/10 flex items-center justify-between gap-4" aria-label="Chapter navigation">
              {prevStep ? (
                <a
                  href={prevStep.path}
                  class="flex items-center gap-2 px-5 py-3 rounded-xl bg-surface-container hover:bg-surface-container-high text-on-surface-variant hover:text-on-surface transition-all duration-200 text-sm font-medium group"
                >
                  <span class="material-symbols-outlined text-xl group-hover:-translate-x-0.5 transition-transform" style="font-size:20px">arrow_back</span>
                  <span>
                    <span class="block text-xs text-on-surface-variant/60 mb-0.5">{copy.previous}</span>
                    {prevStep.label}
                  </span>
                </a>
              ) : <div />}

              {nextStep ? (
                <a
                  href={nextStep.path}
                  class="flex items-center gap-2 px-5 py-3 rounded-xl bg-surface-container hover:bg-surface-container-high text-on-surface-variant hover:text-on-surface transition-all duration-200 text-sm font-medium group text-right"
                >
                  <span>
                    <span class="block text-xs text-on-surface-variant/60 mb-0.5">{copy.next}</span>
                    {nextStep.label}
                  </span>
                  <span class="material-symbols-outlined text-xl group-hover:translate-x-0.5 transition-transform" style="font-size:20px">arrow_forward</span>
                </a>
              ) : (
                <a
                  href="https://app.speakpath.dev"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 px-5 py-3 rounded-xl btn-primary text-sm font-semibold font-headline group"
                >
                  <span>
                    <span class="block text-xs opacity-80 mb-0.5">{copy.done}</span>
                    {copy.practice} →
                  </span>
                  <span class="material-symbols-outlined text-xl group-hover:translate-x-0.5 transition-transform" style="font-size:20px">open_in_new</span>
                </a>
              )}
            </nav>
          )}

          <!-- Mobile Practice CTA (shown on topic pages) -->
          {!isIndex && (
            <div class="mt-8 lg:hidden p-6 rounded-2xl bg-surface-container border border-outline-variant/15 text-center">
              <p class="text-on-surface-variant text-sm mb-4">
                {copy.mobilePractice}
              </p>
              <a
                href="https://app.speakpath.dev"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-semibold font-headline"
              >
                {copy.practice}
                <span class="material-symbols-outlined" style="font-size:18px">open_in_new</span>
              </a>
            </div>
          )}
        </article>
      </div>
    </div>

    <!-- Footer -->
    <footer class="bg-surface-container-low border-t border-outline-variant/10 mt-16">
      <div class="flex flex-col md:flex-row justify-between items-center px-6 md:px-12 py-10 max-w-7xl mx-auto gap-6">
        <div class="flex flex-col gap-2 items-center md:items-start">
          <div class="text-base font-bold text-primary font-headline tracking-tight">SpeakPath</div>
          <p class="text-on-surface-variant text-xs">
            © {new Date().getFullYear()} SpeakPath. {copy.footer}
          </p>
        </div>
        <div class="flex gap-6">
          <a href="/privacy" class="text-on-surface-variant text-xs hover:text-tertiary underline-offset-4 hover:underline transition-colors">{copy.privacy}</a>
          <a href={learnPath} class="text-on-surface-variant text-xs hover:text-tertiary underline-offset-4 hover:underline transition-colors">{copy.learn}</a>
        </div>
      </div>
    </footer>
  </body>
</html>
