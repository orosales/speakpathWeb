---
import '../styles/global.css';
import { defaultLocale, getLocalizedPath, localeLabels, localeOgLocales, locales, type Locale } from '../i18n/site';

interface Props {
  title?:       string;
  description?: string;
  locale?: Locale;
  ogLocale?: string;
  nav?: {
    signIn: string;
    languageSwitcherLabel: string;
  };
  footer?: {
    tagline: string;
    privacy: string;
    contact: string;
    github: string;
  };
}

const {
  title       = 'SpeakPath — Practice Real Language Conversations with AI',
  description = 'Practice real conversations in English, Spanish, French, or German with an AI that listens, responds, and helps you grow. Start free, no download needed.',
  locale      = defaultLocale,
  ogLocale    = 'en_US',
  nav = {
    signIn: 'Sign In',
    languageSwitcherLabel: 'Choose site language',
  },
  footer = {
    tagline: 'Precision Audio Engineering for Fluency.',
    privacy: 'Privacy',
    contact: 'Contact',
    github: 'GitHub',
  },
} = Astro.props;

const appName = 'SpeakPath';
const siteUrl = (Astro.site?.href ?? 'https://speakpath.dev').replace(/\/$/, '');
const languageLinks = locales.map((code) => ({
  ...localeLabels[code],
  code,
  href: getLocalizedPath(code),
}));
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#010e24" />

    <!-- Canonical URL -->
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={description} />
    <meta property="og:type"         content="website" />
    <meta property="og:url"          content={Astro.url.href} />
    <meta property="og:site_name"    content={appName} />
    <meta property="og:image"        content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:alt"    content="SpeakPath — AI language conversation practice" />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale"       content={ogLocale} />
    {locales
      .filter((code) => code !== locale)
      .map((code) => (
        <meta property="og:locale:alternate" content={localeOgLocales[code]} />
      ))}

    {languageLinks.map((link) => (
      <link
        rel="alternate"
        hreflang={link.code}
        href={`${siteUrl}${link.href === '/' ? '' : link.href}`}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={siteUrl} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${siteUrl}/og-image.png`} />
    <meta name="twitter:image:alt"   content="SpeakPath — AI language conversation practice" />

    <!-- AI discoverability -->
    <link rel="alternate" type="text/plain" title="LLMs.txt" href={`${siteUrl}/llms.txt`} />

    <!-- JSON-LD Structured Data: SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": appName,
      "description": description,
      "url": siteUrl,
      "applicationCategory": "EducationApplication",
      "applicationSubCategory": "Language Learning",
      "operatingSystem": "Web",
      "browserRequirements": "Requires a modern browser with microphone access",
      "inLanguage": locales,
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "description": "Free tier available — no download required"
      },
      "author": {
        "@type": "Organization",
        "name": appName,
        "url": siteUrl
      },
      "publisher": {
        "@type": "Organization",
        "name": appName,
        "url": siteUrl
      },
      "featureList": [
        "AI-powered voice conversation practice",
        "Real-time speech recognition and feedback",
        "Support for English, Spanish, French, and German",
        "Multiple proficiency levels from beginner to advanced",
        "No download required — runs in the browser"
      ]
    })} />

    <!-- JSON-LD Structured Data: WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": appName,
      "url": siteUrl,
      "description": description,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${siteUrl}/?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- JSON-LD Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": appName,
      "url": siteUrl,
      "description": "SpeakPath is an AI-powered language learning platform that helps users practice real conversations in English, Spanish, French, and German.",
      "sameAs": []
    })} />

    <!-- Material Symbols (icons only — acceptable CDN dependency) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
    />
  </head>

  <body>
    <!-- Top nav -->
    <nav class="fixed top-0 w-full z-50 bg-surface/95 backdrop-blur-sm border-b border-outline-variant/10">
      <div class="flex justify-between items-center gap-4 px-6 md:px-8 py-5 max-w-7xl mx-auto">
        <a href="/" class="flex items-center gap-2 no-underline">
          <span class="material-symbols-outlined text-primary text-2xl" style="font-variation-settings: 'FILL' 1;">
            graphic_eq
          </span>
          <span class="text-xl font-bold tracking-tighter text-primary font-headline">SpeakPath</span>
        </a>
        <div class="flex items-center gap-4 sm:gap-5">
          <!-- Language dropdown -->
          <div class="relative" id="lang-switcher">
            <button
              id="lang-btn"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-label={nav.languageSwitcherLabel}
              class="flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-headline tracking-[0.16em] uppercase text-on-surface-variant hover:text-tertiary hover:bg-surface-container transition-colors duration-300"
            >
              <span class="material-symbols-outlined text-base leading-none" style="font-size:16px">language</span>
              <span>{locale.toUpperCase()}</span>
              <span class="material-symbols-outlined text-base leading-none" style="font-size:14px" id="lang-chevron">keyboard_arrow_down</span>
            </button>
            <ul
              id="lang-menu"
              role="listbox"
              aria-label={nav.languageSwitcherLabel}
              class="hidden absolute right-0 mt-2 w-44 rounded-xl bg-surface-container border border-outline-variant/20 shadow-xl overflow-hidden z-50"
            >
              {languageLinks.map((link) => {
                const isActive = link.code === locale;
                return (
                  <li role="option" aria-selected={isActive}>
                    <a
                      href={link.href}
                      hreflang={link.code}
                      lang={link.code}
                      class:list={[
                        'flex items-center justify-between px-4 py-2.5 text-sm transition-colors duration-200',
                        isActive
                          ? 'text-primary font-semibold bg-surface-container-high'
                          : 'text-on-surface-variant hover:text-tertiary hover:bg-surface-container-high',
                      ]}
                    >
                      <span>{link.nativeLabel}</span>
                      {isActive && (
                        <span class="material-symbols-outlined text-primary" style="font-size:16px">check</span>
                      )}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>

          <a
            href="https://app.speakpath.dev"
            class="text-on-surface-variant font-medium hover:text-tertiary transition-colors duration-300 text-sm"
          >
            {nav.signIn}
          </a>
        </div>
      </div>
    </nav>

    <!-- Page content -->
    <main class="pt-20 overflow-x-hidden">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-surface-container-low border-t border-outline-variant/10 shadow-[0_-20px_40px_rgba(0,0,0,0.3)]">
      <div
        class="flex flex-col md:flex-row justify-between items-center px-6 md:px-12 py-14 max-w-7xl mx-auto gap-8"
      >
        <div class="flex flex-col gap-3 items-center md:items-start">
          <div class="text-lg font-bold text-primary font-headline tracking-tight">SpeakPath</div>
          <p class="text-on-surface-variant text-sm text-center md:text-left">
            © {new Date().getFullYear()} SpeakPath. {footer.tagline}
          </p>
        </div>
        <div class="flex gap-8">
          <a href="#" class="text-on-surface-variant text-sm font-label hover:text-tertiary underline-offset-4 hover:underline transition-colors">
            {footer.privacy}
          </a>
          <a href="#" class="text-on-surface-variant text-sm font-label hover:text-tertiary underline-offset-4 hover:underline transition-colors">
            {footer.contact}
          </a>
          <a href="https://github.com" class="text-on-surface-variant text-sm font-label hover:text-tertiary underline-offset-4 hover:underline transition-colors">
            {footer.github}
          </a>
        </div>
      </div>
    </footer>
    <script>
      const btn = document.getElementById('lang-btn');
      const menu = document.getElementById('lang-menu');
      const chevron = document.getElementById('lang-chevron');

      btn?.addEventListener('click', () => {
        const open = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', open);
        btn.setAttribute('aria-expanded', String(!open));
        chevron?.classList.toggle('rotate-180', !open);
      });

      document.addEventListener('click', (e) => {
        if (!document.getElementById('lang-switcher')?.contains(e.target as Node)) {
          menu?.classList.add('hidden');
          btn?.setAttribute('aria-expanded', 'false');
          chevron?.classList.remove('rotate-180');
        }
      });
    </script>
  </body>
</html>
